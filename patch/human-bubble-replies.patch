+import { describe, expect, it, vi } from "vitest";
+import {
+  createSubscribedSessionHarness,
+  emitMessageStartAndEndForAssistantText,
+} from "./pi-embedded-subscribe.e2e-harness.js";
+
+describe("subscribeEmbeddedPiSession human bubble block replies", () => {
+  it("emits human bubble markers as separate Telegram DM block replies", async () => {
+    const onBlockReply = vi.fn();
+    const { emit } = createSubscribedSessionHarness({
+      runId: "run",
+      onBlockReply,
+      blockReplyBreak: "message_end",
+      humanBubbleScope: { channel: "telegram", chatType: "direct" },
+    } as never);
+
+    emitMessageStartAndEndForAssistantText({
+      emit,
+      text: "早，醒了吗<bubble:1000>外面在下雨<bubble:300>出门记得带伞",
+    });
+
+    await vi.waitFor(() => {
+      expect(onBlockReply).toHaveBeenCalledTimes(3);
+    });
+    expect(
+      onBlockReply.mock.calls.map((call) => {
+        const payload = call[0] as { text?: string; bubbleDelayMs?: number };
+        return { text: payload.text, bubbleDelayMs: payload.bubbleDelayMs };
+      }),
+    ).toEqual([
+      { text: "早，醒了吗", bubbleDelayMs: 0 },
+      { text: "外面在下雨", bubbleDelayMs: 1000 },
+      { text: "出门记得带伞", bubbleDelayMs: 300 },
+    ]);
+  });
+
+  it("strips human bubble markers in unsupported block reply scope", async () => {
+    const onBlockReply = vi.fn();
+    const { emit } = createSubscribedSessionHarness({
+      runId: "run",
+      onBlockReply,
+      blockReplyBreak: "message_end",
+      humanBubbleScope: { channel: "telegram", chatType: "group" },
+    } as never);
+
+    emitMessageStartAndEndForAssistantText({
+      emit,
+      text: "早，醒了吗<bubble:1000>醒了？",
+    });
+
+    await vi.waitFor(() => {
+      expect(onBlockReply).toHaveBeenCalledTimes(1);
+    });
+    expect(
+      onBlockReply.mock.calls.map((call) => {
+        const payload = call[0] as { text?: string; bubbleDelayMs?: number };
+        return { text: payload.text, bubbleDelayMs: payload.bubbleDelayMs };
+      }),
+    ).toEqual([{ text: "早，醒了吗醒了？", bubbleDelayMs: undefined }]);
+  });
+});
